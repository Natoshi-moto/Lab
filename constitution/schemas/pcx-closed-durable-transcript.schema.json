{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexus.pcx-closed-durable-transcript/v0",
  "title": "R015 closed export of one R014 durable prefix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "network_id",
    "genesis_id",
    "genesis_b64",
    "genesis_raw_sha256",
    "initial_state_root",
    "max_records",
    "record_count",
    "records",
    "anchors",
    "terminal_anchor",
    "closure",
    "status_authority",
    "transcript_id"
  ],
  "properties": {
    "schema": { "const": "nexus.pcx-closed-durable-transcript/v0" },
    "network_id": { "const": "NEXUS-R013-SYNTHETIC" },
    "genesis_id": { "const": "974cd4da89feb9f7ae8e14d7b4359f4b76d8697f55e5793219c52e38b627b7de" },
    "genesis_b64": { "type": "string", "maxLength": 87384 },
    "genesis_raw_sha256": { "$ref": "#/$defs/hash" },
    "initial_state_root": { "$ref": "#/$defs/hash" },
    "max_records": { "const": "256" },
    "record_count": { "$ref": "#/$defs/sequence" },
    "records": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/record" }
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 257,
      "items": { "$ref": "#/$defs/anchor" }
    },
    "terminal_anchor": { "$ref": "#/$defs/anchor" },
    "closure": { "const": "CLOSED_EXPORTED_PREFIX" },
    "status_authority": { "const": "NONE" },
    "transcript_id": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "sequence": { "type": "string", "pattern": "^(?:0|[1-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-6])$" },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema", "sequence", "previous_record_hash", "record_hash", "tx_id",
        "tx_b64", "tx_sha256", "previous_state_root", "next_state_root",
        "receipt_hash", "receipt_b64", "receipt_raw_sha256", "status_authority"
      ],
      "properties": {
        "schema": { "const": "nexus.pcx-durable-record/v0" },
        "sequence": { "$ref": "#/$defs/sequence" },
        "previous_record_hash": { "type": "string", "pattern": "^(?:|[0-9a-f]{64})$" },
        "record_hash": { "$ref": "#/$defs/hash" },
        "tx_id": { "$ref": "#/$defs/hash" },
        "tx_b64": { "type": "string", "maxLength": 87384 },
        "tx_sha256": { "$ref": "#/$defs/hash" },
        "previous_state_root": { "$ref": "#/$defs/hash" },
        "next_state_root": { "$ref": "#/$defs/hash" },
        "receipt_hash": { "$ref": "#/$defs/hash" },
        "receipt_b64": { "type": "string", "maxLength": 87384 },
        "receipt_raw_sha256": { "$ref": "#/$defs/hash" },
        "status_authority": { "const": "NONE" }
      }
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema", "network_id", "genesis_id", "sequence", "record_hash",
        "state_root", "receipt_head", "status_authority", "anchor_id"
      ],
      "properties": {
        "schema": { "const": "nexus.pcx-durable-anchor/v0" },
        "network_id": { "const": "NEXUS-R013-SYNTHETIC" },
        "genesis_id": { "const": "974cd4da89feb9f7ae8e14d7b4359f4b76d8697f55e5793219c52e38b627b7de" },
        "sequence": { "$ref": "#/$defs/sequence" },
        "record_hash": { "type": "string", "pattern": "^(?:|[0-9a-f]{64})$" },
        "state_root": { "$ref": "#/$defs/hash" },
        "receipt_head": { "type": "string", "pattern": "^(?:|[0-9a-f]{64})$" },
        "status_authority": { "const": "NONE" },
        "anchor_id": { "$ref": "#/$defs/hash" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "sequence": { "const": "0" } },
            "required": ["sequence"]
          },
          "then": {
            "properties": {
              "record_hash": { "const": "" },
              "receipt_head": { "const": "" }
            }
          },
          "else": {
            "properties": {
              "record_hash": { "$ref": "#/$defs/hash" },
              "receipt_head": { "$ref": "#/$defs/hash" }
            }
          }
        }
      ]
    }
  }
}
