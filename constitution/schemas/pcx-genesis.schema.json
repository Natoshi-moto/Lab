{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexus.pcx-genesis/v0",
  "title": "R013 frozen synthetic PCX genesis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "network_id",
    "unit_label",
    "outputs",
    "status_authority",
    "genesis_id"
  ],
  "properties": {
    "schema": { "const": "nexus.pcx-genesis/v0" },
    "network_id": { "const": "NEXUS-R013-SYNTHETIC" },
    "unit_label": { "const": "R013-SYNTHETIC-CLAIM" },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/output" }
    },
    "status_authority": { "const": "NONE" },
    "genesis_id": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "amount": { "type": "string", "pattern": "^(?:[1-9]|[1-9][0-9]{1,2}|1000)$" },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_public_key", "amount"],
      "properties": {
        "owner_public_key": { "$ref": "#/$defs/hash" },
        "amount": { "$ref": "#/$defs/amount" }
      }
    }
  }
}
