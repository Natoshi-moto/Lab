{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexus.pcx-transfer/v0",
  "title": "R013 signed synthetic PCX transfer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "network_id",
    "genesis_id",
    "anchor_state_root",
    "nonce",
    "inputs",
    "outputs",
    "tx_id",
    "witnesses",
    "status_authority"
  ],
  "properties": {
    "schema": { "const": "nexus.pcx-transfer/v0" },
    "network_id": { "const": "NEXUS-R013-SYNTHETIC" },
    "genesis_id": { "$ref": "#/$defs/hash" },
    "anchor_state_root": { "$ref": "#/$defs/hash" },
    "nonce": { "$ref": "#/$defs/hash" },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/input" }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/output" }
    },
    "tx_id": { "$ref": "#/$defs/hash" },
    "witnesses": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/witness" }
    },
    "status_authority": { "const": "NONE" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "amount": { "type": "string", "pattern": "^(?:[1-9]|[1-9][0-9]{1,2}|1000)$" },
    "index": { "type": "string", "pattern": "^[0-7]$" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["creating_tx_id", "output_index", "output_id"],
      "properties": {
        "creating_tx_id": { "$ref": "#/$defs/hash" },
        "output_index": { "$ref": "#/$defs/index" },
        "output_id": { "$ref": "#/$defs/hash" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_public_key", "amount"],
      "properties": {
        "owner_public_key": { "$ref": "#/$defs/hash" },
        "amount": { "$ref": "#/$defs/amount" }
      }
    },
    "witness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_index", "owner_public_key", "signature"],
      "properties": {
        "input_index": { "$ref": "#/$defs/index" },
        "owner_public_key": { "$ref": "#/$defs/hash" },
        "signature": { "type": "string", "pattern": "^[0-9a-f]{128}$" }
      }
    }
  }
}
