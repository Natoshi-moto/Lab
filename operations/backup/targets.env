# Emergency multi-drive snapshot targets (one path per line after SOURCES/TARGETS markers)
# Writable mount points only; missing mounts are skipped with a warning.

MAX_SNAPSHOTS=20

# Source roots to copy (name|absolute_path)
SOURCE_Lab=/home/anon/audit-lab/Lab
SOURCE_LabRecovery=/home/anon/Lab-Recovery

# Destination roots — each gets SNAPSHOTS/<timestamp>_<sha>/...
TARGET_mnt_backup=/mnt/backup/lab-emergency-snapshots
TARGET_mnt_games=/mnt/games/lab-emergency-snapshots
TARGET_home_mirror=/home/anon/nexus-backup/lab-emergency-snapshots

# Optional USB: when you plug in a stick, either:
#  1) mount it and set TARGET_usb=/run/media/anon/<LABEL>/lab-emergency-snapshots
#  2) or create a directory named lab-emergency-snapshots on the stick root
#    and the script will auto-discover under /run/media/$USER/*/lab-emergency-snapshots
USB_AUTODISCOVER=1
